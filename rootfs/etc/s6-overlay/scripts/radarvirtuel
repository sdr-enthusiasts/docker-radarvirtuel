source /scripts/common

START_DELAY=5s

export RV_LAT="${RV_LAT:-$LAT}"
export RV_LON="${RV_LON:-$LON}"
export RV_ALT="${RV_ALT:-$ALT}"

if [[ -n "$RV_SERVER" || -n "$FEEDER_KEY" ]]; then
    sleep 2 
    "${s6wrap[@]}" echo "-----------------------------------------------------------------------------"
    "${s6wrap[@]}" echo "ATTENTION - this container has been updated, but your environment variables"
    "${s6wrap[@]}" echo "are still reflecting the old configuration. Please update your configuration"
    "${s6wrap[@]}" echo "Please update your configuration using this example:"
    "${s6wrap[@]}" echo "https://sdr-e.com/docker-radarvirtuel/blob/main/docker-compose.yml"
    "${s6wrap[@]}" echo "The container is HALTED until you make these updates."
    "${s6wrap[@]}" echo "Then remove these parameters from your configuration to make this message go away:"
    [[ -n "$RV_SERVER" ]] && "${s6wrap[@]}" echo "RV_SERVER=$RV_SERVER" || true
    [[ -n "$FEEDER_KEY" ]] && "${s6wrap[@]}" echo "FEEDER_KEY=$FEEDER_KEY" || true
    "${s6wrap[@]}" echo "-----------------------------------------------------------------------------"
    stop_service
fi

if [[ -z "$RV_CONTRIB_NAME" || -z "$RV_CONTRIB_EMAIL" ]]; then
    sleep 2 
    "${s6wrap[@]}" echo "-----------------------------------------------------------------------------"
    "${s6wrap[@]}" echo "ATTENTION - the RV_CONTRIB_NAME and RV_CONTRIB_EMAIL environment variables are not set."
    "${s6wrap[@]}" echo "Please update your configuration using this example:"
    "${s6wrap[@]}" echo "https://sdr-e.com/docker-radarvirtuel/blob/main/docker-compose.yml"
    "${s6wrap[@]}" echo "The container is HALTED until you make these updates."
    "${s6wrap[@]}" echo "-----------------------------------------------------------------------------"
    stop_service
fi

execstr="python3 -u /docker-entrypoint.py"

if [[ -n "$START_DELAY" ]]; then sleep "$START_DELAY"; fi

"${s6wrap[@]}" echo "Starting ${execstr[@]}"
# shellcheck disable=SC2068
exec "${s6wrap[@]}" ${execstr[@]}
